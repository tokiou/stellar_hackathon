# front public env example
# Source of truth: front/docs/frontend-spec.md

# Dynamic public environment id from the Dynamic dashboard.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=your_dynamic_environment_id_here

# Optional public RPC override used by Dynamic's Solana connector.
# Prefer devnet/localnet for development; do not put provider API secrets here.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Legacy Phantom Embedded app id from phantom.com/portal.
# Kept only while the Phantom-direct path is being migrated behind useWallet().
NEXT_PUBLIC_PHANTOM_APP_ID=your_phantom_app_id_here

# Do NOT put backend API keys, session secrets, Dynamic API keys, private keys,
# Helius, Birdeye, Jupiter, risk-score or execution keys in front env.
# Those belong server-side in root/Vercel/backend configuration consumed by
# app/api/* or back/services/*.
