# back service env vars.
# In Next, configure these in root .env.local or directly in Vercel.

DYNAMIC_ENVIRONMENT_ID=
DYNAMIC_API_KEY=
DYNAMIC_WEBHOOK_SECRET=
APP_SESSION_SECRET=

JUPITER_API_URL=https://lite-api.jup.ag/swap/v1

BIRDEYE_API_KEY=
BIRDEYE_API_URL=https://public-api.birdeye.so

RISK_SCORE_API_KEY=
RISK_SCORE_API_URL=

HELIUS_API_KEY=
