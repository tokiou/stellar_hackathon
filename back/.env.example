OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.3-codex
OPENAI_RESPONSES_ENDPOINT=https://khora-ai.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview
