# Compass MCP Guard env example
# Copy only the variables you need into .env.local or your deployment provider.
# Do not commit real secrets.

# Solana network
SOLANA_RPC_URL=https://api.devnet.solana.com

# Stellar network (Stellar Wave 1 — Testnet only).
# Compass on Stellar is testnet-only; a mainnet passphrase is rejected.
# STELLAR_NETWORK_PASSPHRASE is required (never assumed) and must match Testnet.
STELLAR_NETWORK=testnet
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
# Optional stub price used to value native XLM in USD (analogous to FALLBACK_SOL_USD_PRICE).
FALLBACK_XLM_USD_PRICE=0.1

# Stellar co-signer provider: local (raw seed, Wave 4) or privy (custodied, Ed25519 raw-sign).
COMPASS_STELLAR_SIGNER_PROVIDER=local
# local provider (Wave 4):
COMPASS_STELLAR_SIGNER_ENABLED=
COMPASS_STELLAR_SIGNER_SECRET=
# privy provider: Privy app + Stellar server wallet (do not commit secrets).
PRIVY_APP_ID=
PRIVY_APP_SECRET=
COMPASS_STELLAR_PRIVY_WALLET_ID=
COMPASS_STELLAR_PRIVY_WALLET_PUBLIC_KEY=

# Anchor program used by hosted/onchain/onchainApproval.ts.
# See docs/onchain-deployments.md for the latest devnet program ID.
AGENT_ACTION_GUARD_PROGRAM_ID=

# Optional wallet-safety attestor keypair.
# Prefer the *_FILE variant locally so key material is not embedded in shell history.
WALLET_SAFETY_ATTESTOR_SECRET_KEY_FILE=
WALLET_SAFETY_ATTESTOR_SECRET_KEY=

# Local signer for devnet demo mode.
# COMPASS_LOCAL_SIGNER_SECRET_KEY is the preferred shorter alias for the base58 secret key.
# COMPASS_LOCAL_SIGNER_SECRET_KEY_B58 is the original name (still supported).
# COMPASS_LOCAL_SIGNER_PUBLIC_KEY is optional; when set, the signer validates that the
# derived address matches and rejects mismatches with LOCAL_SIGNER_PUBLIC_KEY_MISMATCH.
COMPASS_LOCAL_SIGNER_ENABLED=
COMPASS_LOCAL_SIGNER_SECRET_KEY=
COMPASS_LOCAL_SIGNER_SECRET_KEY_B58=
COMPASS_LOCAL_SIGNER_PUBLIC_KEY=

# Optional devnet quote fallback used by priceProviders/orcaUsdcSol.ts when allow_fallback=true.
FALLBACK_SOL_USD_PRICE=140

# Compass Wave 9 LLM judge defaults
# Set COMPASS_LLM_DECISION_ENABLED=true to call the optional advisory judge.
# The judge is fail-safe: missing/invalid config preserves deterministic guardrail decisions.
COMPASS_LLM_DECISION_ENABLED=false
COMPASS_LLM_PROVIDER=opencode-go
COMPASS_LLM_MODEL=kimi-k2.5
# COMPASS_LLM_BASE_URL points to the OpenCode Go chat completions endpoint.
# Keep this URL unless you are testing against a different OpenCode-compatible gateway.
COMPASS_LLM_BASE_URL=https://opencode.ai/zen/go/v1/chat/completions
# Optional API key for the LLM provider. Required for OpenAI; optional for OpenCode Go if it doesn't require auth.
COMPASS_LLM_API_KEY=
COMPASS_LLM_TIMEOUT_MS=3000

# PostHog analytics (server-side event tracking)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Debug logging (comma-separated modules: proxy, policy, gateway, execution, interceptor, llm, signer, connection, audit)
COMPASS_DEBUG=

# Installation ID for analytics correlation
COMPASS_INSTALLATION_ID=

# LLM Router (optional — classifies tool calls as transfer/swap/skip/unknown)
COMPASS_LLM_ROUTER_ENABLED=false
COMPASS_LLM_ROUTER_TIMEOUT_MS=10000

# Hosted backend (when running locally with hybrid guard)
COMPASS_HOSTED_PORT=3001
COMPASS_HYBRID_GUARD_ENABLED=true
COMPASS_HOSTED_API_URL=http://localhost:3001
COMPASS_HOSTED_API_KEY=
COMPASS_HOSTED_TIMEOUT_MS=5000
