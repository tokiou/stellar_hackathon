# PromiseKeeper Next Fullstack
# Copy to .env.local for local development or configure these in Vercel.

# Client-safe public config
NEXT_PUBLIC_SOLANA_NETWORK=devnet
VITE_SOLANA_NETWORK=devnet

# Server-side only. Do not expose these in frontend code.
JUPITER_API_URL=https://lite-api.jup.ag/swap/v1
AGENT_ACTION_GUARD_PROGRAM_ID=ETLBetVBpHeG3pKKqpCaRQYfQ2opMNEKCsrQUyqgyg6s
CONDITIONAL_ESCROW_BUY_PROGRAM_ID=FDwvY7eqeCNn27haATZJbqfnACJTr9YveG6yy9RcUt7u
SOLANA_RPC_URL=https://api.devnet.solana.com
WALLET_SAFETY_ATTESTOR_SECRET_KEY=
WALLET_SAFETY_ATTESTOR_SECRET_KEY_FILE=
USDC_TEST_MINT=
USDC_TEST_DECIMALS=6
TREASURY_USDC_ATA=
# Pyth SOL/USD price account address (NOT the feed ID!)
# Devnet: J83w4HKfqxwcq3BEMMkPFSppX3gqekLyLJBexebFVkix
PYTH_SOL_USD_PRICE_ACCOUNT=J83w4HKfqxwcq3BEMMkPFSppX3gqekLyLJBexebFVkix
CONDITIONAL_MAX_ORACLE_AGE_SECONDS=120
CONDITIONAL_MAX_CONFIDENCE_BPS=500
CONDITIONAL_ORDER_TTL_SECONDS=3600

# Swap Guard Oracle Configuration
SWAP_ORACLE_GUARD_ENABLED=true
SWAP_GUARD_WARNING_DEVIATION_BPS=150
SWAP_GUARD_MAX_DEVIATION_BPS=500
# For devnet with legacy Pyth accounts, use high staleness tolerance
# For mainnet with Pyth Pull, use lower values like 60
SWAP_GUARD_STALENESS_SECONDS=86400
SWAP_GUARD_MAX_CONFIDENCE_BPS=100

CONDITIONAL_ORDER_KEEPER_ENABLED=false
CONDITIONAL_ORDER_KEEPER_KEYPAIR=
CONDITIONAL_ORDER_INDEX_INTERVAL_MS=15000
CONDITIONAL_ORDER_ORACLE_POLL_MS=10000
CONDITIONAL_ORDER_EXECUTE_BACKOFF_MS=45000

BIRDEYE_API_KEY=
BIRDEYE_API_URL=https://public-api.birdeye.so

RISK_SCORE_API_KEY=
RISK_SCORE_API_URL=

HELIUS_API_KEY=
HELIUS_API_URL=https://api.helius.xyz

# Optional wallet safety tuning (transfer destination guardrails)
WALLET_SAFETY_PROVIDER_MODE=mock
WALLET_SAFETY_MAX_TRANSFER_SOL=20
WALLET_SAFETY_WARN_TRANSFER_SOL=5
WALLET_SAFETY_SOLSCAN_ENABLED=false
WALLET_SAFETY_SOLSCAN_BASE_URL=https://pro-api.solscan.io/v2.0
WALLET_SAFETY_SOLSCAN_API_KEY=
WALLET_SAFETY_SOLSCAN_TIMEOUT_MS=2500
