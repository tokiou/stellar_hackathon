{
  "name": "@ramadan04/compass-mcp-guard",
  "version": "0.1.0",
  "description": "Execution firewall for AI agents on Solana. MCP proxy that validates, simulates, approves and audits every sensitive on-chain action before an AI agent can execute it.",
  "type": "module",
  "bin": {
    "compass-mcp-guard": "dist/mcpServer.js"
  },
  "main": "dist/mcpServer.js",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ram4-dev/solana_hackathon.git"
  },
  "keywords": [
    "mcp",
    "solana",
    "ai-agent",
    "security",
    "guardrail",
    "execution-firewall",
    "policy-engine",
    "crypto",
    "wallet"
  ],
  "author": "ramadan04",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:mcp": "tsup",
    "start": "next start",
    "lint": "eslint app back hosted shared",
    "test": "vitest --config vitest.back.config.ts --run",
    "test:back": "vitest --config vitest.back.config.ts --run",
    "test:watch": "vitest --config vitest.back.config.ts",
    "hosted:dev": "bun hosted/server.ts",
    "mcp:dev": "tsx back/services/mcp/server/mcpServer.ts",
    "mcp:install:opencode": "node scripts/install-opencode-mcp.mjs",
    "test:e2e": "node scripts/e2e-pipeline-test.mjs",
    "test:e2e:verbose": "node scripts/e2e-pipeline-test.mjs --verbose",
    "ticket:process": "tsx scripts/ticket-orchestrator.ts process",
    "ticket:approve": "tsx scripts/ticket-orchestrator.ts approve",
    "ticket:status": "tsx scripts/ticket-orchestrator.ts status"
  },
  "dependencies": {
    "@coral-xyz/anchor": "~0.32.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@orca-so/common-sdk": "^0.7.0",
    "@orca-so/whirlpools-sdk": "^0.20.0",
    "@solana/web3.js": "^1.98.4",
    "@stellar/stellar-sdk": "^15.1.0",
    "bs58": "^6.0.0",
    "hono": "^4.12.25",
    "next": "^15.5.16",
    "posthog-node": "^5.38.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "globals": "^15.9.0",
    "gray-matter": "^4.0.3",
    "sharp": "^0.34.5",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vitest": "^1.0.4"
  }
}
